# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://essorqboloappvfwjcbh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key for server-side operations (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# NewsData.io — get from https://newsdata.io
NEWSAPI_KEY=pub_your_key_here

# Alpha Vantage FX API — get from https://www.alphavantage.co
ALPHA_VANTAGE_KEY=your_alpha_key_here

# Blogger Blog ID — get from Blogger Settings → Advanced
BLOGGER_BLOG_ID=your_blog_id

# Blogger Access Token — get from Google Cloud Console
BLOGGER_ACCESS_TOKEN=your_token

# Google Gemini AI API — get from https://aistudio.google.com/app
GEMINI_API_KEY=your_gemini_api_key_here

# Blogger JSON API (optional) — get from Google Cloud Console
BLOGGER_BLOG_ID=your_blog_id
BLOGGER_ACCESS_TOKEN=your_access_token

# Unsplash (optional) — get from https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_key

# Resend — for email notifications (optional)
RESEND_API_KEY=re_your_key_here
CONTACT_EMAIL=your@email.com
